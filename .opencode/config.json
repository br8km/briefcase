{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "opencode/big-pickle",
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "permission": {
        "bash": "allow"
      },
      "timeout": 1200000
    }
  },
  "lsp": {
    "rust": {
      "env": {
        "RUST_LOG": "error"
      },
      "initialization": {
        "cargo": {
          "allTargets": false,
          "buildScripts": true,
          "features": "all"
        },
        "checkOnSave": {
          "command": "clippy"
        },
        "completion": {
          "autoimport": {
            "enable": true
          },
          "snippets": {
            "enable": true
          }
        },
        "hover": {
          "documentation": true,
          "links": true
        },
        "procMacro": {
          "enable": true
        }
      }
    }
  }
}
